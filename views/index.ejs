<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>仕様書・設計書生成ツール</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>仕様書・設計書生成ツール</h1>
        </header>

        <main>
            <form id="documentForm" class="input-section">
                <div class="form-group">
                    <label for="textInput">テキスト入力（必須・500文字まで）</label>
                    <textarea 
                        id="textInput" 
                        name="text" 
                        rows="6" 
                        maxlength="500" 
                        placeholder="生成したい文書の要件を入力してください..."
                        required
                    ></textarea>
                    <div class="char-counter">
                        <span id="charCount">0</span>/500
                    </div>
                </div>

                <div class="form-group">
                    <label>画像アップロード（任意・1枚まで）</label>
                    <div id="dropZone" class="drop-zone">
                        <p>画像をドラッグ&ドロップ または クリックして選択</p>
                        <input type="file" id="imageInput" name="image" accept="image/*" hidden>
                        <div id="imagePreview" class="image-preview"></div>
                    </div>
                </div>

                <div class="form-group form-inline">
                    <label for="documentType">文書種類：</label>
                    <select id="documentType" name="documentType">
                        <option value="specification" selected>仕様書</option>
                        <option value="design">設計書</option>
                        <option value="confirmation">確認書</option>
                    </select>
                    <button type="submit" id="generateBtn" class="btn-primary">生成</button>
                </div>

                <div id="errorMessage" class="error-message" style="display: none;"></div>
            </form>

            <div id="resultSection" class="result-section" style="display: none;">
                <h2>生成結果</h2>
                <div id="documentOutput" class="document-output"></div>
            </div>

            <div id="loadingSpinner" class="loading-spinner" style="display: none;">
                <div class="spinner"></div>
                <p>文書を生成中...</p>
            </div>
        </main>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>
